APP_CONFIG__RUN__HOST=127.0.0.1

APP_CONFIG__DB__URL=postgresql+asyncpg://gitmetrics_user:gitmetrics_password@localhost:5432/gitmetrics
APP_CONFIG__DB__ECHO=0

# JWT — change this to a long random string in production!
APP_CONFIG__AUTH__SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
APP_CONFIG__AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI — leave empty to use the local (no-API) report generator
APP_CONFIG__OPENAI__API_KEY=
APP_CONFIG__OPENAI__MODEL=gpt-4o-mini
