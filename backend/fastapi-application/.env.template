APP_CONFIG__RUN__HOST=127.0.0.1

APP_CONFIG__DB__URL=postgresql+asyncpg://gitmetrics_user:gitmetrics_password@localhost:5432/gitmetrics
APP_CONFIG__DB__ECHO=0

APP_CONFIG__AUTH__SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
APP_CONFIG__AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── LLM provider (OpenAI-compatible) ────────────────────────────────────────
# Leave API_KEY empty to use the built-in local report generator (no external calls).
#
# Option A — OpenAI:
#   APP_CONFIG__OPENAI__API_KEY=sk-...
#   APP_CONFIG__OPENAI__BASE_URL=
#   APP_CONFIG__OPENAI__MODEL=gpt-4o-mini
#
# Option B — OpenRouter (https://openrouter.ai):
#   APP_CONFIG__OPENAI__API_KEY=sk-or-v1-...
#   APP_CONFIG__OPENAI__BASE_URL=https://openrouter.ai/api/v1
#   APP_CONFIG__OPENAI__MODEL=qwen/qwen3.6-plus:free   ← free tier, no credits needed
#   (any model from https://openrouter.ai/models works here; use :free suffix for free models)
APP_CONFIG__OPENAI__API_KEY=
APP_CONFIG__OPENAI__BASE_URL=
APP_CONFIG__OPENAI__MODEL=
